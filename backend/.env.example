# ─── Server ─────────────────────────────────────────
PORT=3001

# ─── Database & Uploads ─────────────────────────────
DB_PATH=./taskflow.json
UPLOADS_DIR=./uploads

# Set this to your deployed app's public URL (no trailing slash).
# Required for sending images via WhatsApp — Twilio fetches the image from this URL.
# Example: https://taskflow.up.railway.app
PUBLIC_BASE_URL=

# ─── Twilio WhatsApp ─────────────────────────────────
# Sign up free at https://www.twilio.com
# Use Sandbox: "whatsapp:+14155238886"
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=+14155238886

# ─── Translation ─────────────────────────────────────
# Uses MyMemory API (free, no key required) — nothing to configure here.
